# FireAI Environment Configuration Template
# ============================================
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.

# === AI Provider Keys ===
OPENAI_API_KEY=
GEMINI_API_KEY=

# === AI Memory Configuration ===
FIREAI_MEMORY_LLM_PROVIDER=openai
FIREAI_MEMORY_LLM_MODEL=gpt-4o-mini
FIREAI_MEMORY_EMBEDDER_PROVIDER=openai
FIREAI_MEMORY_EMBEDDER_MODEL=text-embedding-3-small

# === Wiki Configuration ===
FIREAI_WIKI_ROOT=

# === FireAI API ===
# SECURITY: Generate a strong random key! Do NOT use the example below.
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(32))"
FIREAI_API_KEY=
# SECURITY: HMAC key for evidence package tamper-proofing.
# Must be at least 32 bytes. Generate with:
# python -c "import secrets; print(secrets.token_hex(32))"
FIREAI_EVIDENCE_HMAC_KEY=
AUDIT_HMAC_KEY=
LOG_LEVEL=INFO

# === Database ===
DATABASE_URL=sqlite:///data/fireai.db

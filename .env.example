# FireAI Environment Configuration Template
# ============================================
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.

# ── Application ──────────────────────────────────────────────────────────────
# Environment: "production" or "development"
# - production: Requires FIREAI_API_KEY, strict CORS, no unsafe-eval CSP
# - development: API key optional, relaxed CORS, unsafe-eval allowed
FIREAI_ENV=production

# Server host and port
HOST=0.0.0.0
PORT=8000

# Log level: DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_LEVEL=INFO

# ── Security ─────────────────────────────────────────────────────────────────
# API key for authenticating all API requests (required in production).
# Generate a strong random key (min 32 chars):
#   python -c "import secrets; print(secrets.token_hex(32))"
FIREAI_API_KEY=

# ── Database ─────────────────────────────────────────────────────────────────
# Database URL — determines the database backend:
#   - SQLite (default): sqlite:///./db/digital_twin.db
#   - PostgreSQL (production): postgresql://user:password@host:5432/dbname
# If DATABASE_URL starts with "postgres://" or "postgresql://", PostgreSQL mode
# is activated with connection pooling (2-20 connections).
DATABASE_URL=sqlite:///./db/digital_twin.db

# SQLite-specific: Path to the Digital Twin database file
DIGITAL_TWIN_DB_PATH=./db/digital_twin.db

# UDM (Universal Data Model) database path
UDM_DB_PATH=./db/udm_elements.db

# ── CORS (Cross-Origin Resource Sharing) ─────────────────────────────────────
# Comma-separated allowed origins (wildcard "*" is always rejected)
# Production: Must be explicitly configured or no origins are allowed
# Development: localhost defaults are provided automatically
CORS_ORIGINS=http://localhost:5173,http://localhost:8000

# ── Content Security Policy ──────────────────────────────────────────────────
# Allow 'unsafe-eval' in CSP? (false = secure, true = allows eval/Function)
# Production default: false (secure-by-default)
# Development default: true (for Vite/HMR hot-reload)
CSP_UNSAFE_EVAL=false

# Allowed connection sources for CSP connect-src directive
# Required for WebSocket connections and external API calls
CSP_CONNECT_SRC=http://localhost:5173 ws://localhost:5173 http://localhost:8000

# ── External APIs (optional — system works with conservative defaults) ───────
# World Air Quality Index API token (required for air quality data)
# Get a free token at https://aqicn.org/data-platform/token/
WAQI_API_TOKEN=

# OpenAI API key (for memory service, optional)
# OPENAI_API_KEY=
# FIREAI_OPENAI_API_KEY=

# Google Gemini API key (for memory service, optional)
# GEMINI_API_KEY=

# ── File Upload / DWG Parsing ───────────────────────────────────────────────
# Colon-separated directories where DWG files can be uploaded from
FIREAI_DATA_DIRS=/tmp/fireai_uploads:/data:/uploads

# Colon-separated directories allowed for file uploads
FIREAI_ALLOWED_UPLOAD_DIRS=/tmp:/var/tmp:/var/fireai/uploads

# Maximum DWG file size in bytes (default: 100MB)
FIREAI_DWG_MAX_FILE_SIZE_BYTES=104857600

# ── Evidence & Encryption ────────────────────────────────────────────────────
# Evidence chain HMAC key (for audit trail integrity)
FIREAI_EVIDENCE_HMAC_KEY=

# Encryption key for sensitive data at rest
ENCRYPTION_KEY=

# ── Redis ─────────────────────────────────────────────────────────────────────
# Redis configuration (for rate limiting and caching)
REDIS_URL=redis://localhost:6379/0
REDIS_PASSWORD=

# ── Worker Configuration ──────────────────────────────────────────────────────
# Worker mode for distributed processing
WORKER_MODE=false

# ── External Service URLs (override defaults if needed) ──────────────────────
# REST Countries API (for region detection)
# REST_COUNTRIES_API_URL=https://restcountries.com/v3.1/alpha

# National Weather Service API (for US severe weather alerts)
# NWS_API_URL=https://api.weather.gov/alerts
# NWS_POINTS_URL=https://api.weather.gov/points

# MeteoAlarm API (for European weather warnings)
# METEOALARM_API_URL=https://api.meteoalarm.org/api/v1/warnings
# METEOALARM_ATOM_URL=https://feeds.meteoalarm.org/feeds/meteoalarm-legacy-atom-country

# Open-Meteo API (for international weather forecasts)
# OPENMETEO_ALERTS_URL=https://api.open-meteo.com/v1/forecast

# Tempo distributed tracing endpoint
# TEMPO_ENDPOINT=http://tempo:4318/v1/traces

# ── Frontend WebSocket ───────────────────────────────────────────────────────
# WebSocket URL for live telemetry data (used by frontend DataService)
# If not set, derives from window.location at runtime
# VITE_WS_URL=ws://localhost:8000/ws

# ═══════════════════════════════════════════════════════════════════════════
# FireAI Digital Twin — Environment Variables
# ═══════════════════════════════════════════════════════════════════════════
# Copy this file to .env and fill in the values.
# NEVER commit .env files to version control!
# ═══════════════════════════════════════════════════════════════════════════

# ── Deployment Mode ───────────────────────────────────────────────────────
# Set to "development" for local dev (auto-auth, verbose logs, hot-reload).
# Set to "production" for deployment (requires API key, strict CSP, WAL checkpoint).
FIREAI_ENV=development

# ── API Security ──────────────────────────────────────────────────────────
# Required in production. In development, auth is auto-bypassed for localhost.
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(32))"
FIREAI_API_KEY=

# ── Database ──────────────────────────────────────────────────────────────
# SQLite (default, for development):
DATABASE_URL=sqlite:///./db/digital_twin.db
UDM_DB_PATH=./db/udm_elements.db

# PostgreSQL (for production multi-worker deployments):
# DATABASE_URL=postgresql+asyncpg://user:password@host:5432/fireai
# DB_USER=fireai
# DB_PASSWORD=change_me
# DB_NAME=fireai

# ── Redis (required for production multi-worker) ─────────────────────────
REDIS_PASSWORD=change_me
REDIS_URL=redis://:change_me@localhost:6379/0

# ── LLM / Memory Service (optional) ──────────────────────────────────────
# At least one API key required for MemoryService to initialize.
# GEMINI_API_KEY=your_gemini_key_here
# OPENAI_API_KEY=your_openai_key_here

# ── Evidence Chain HMAC (required for audit integrity) ───────────────────
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
# FIREAI_EVIDENCE_HMAC_KEY=your_hmac_key_here

# ── CORS ──────────────────────────────────────────────────────────────────
# Comma-separated list of allowed origins. In development, defaults to
# localhost:3000, :5173, :8000. In production, must be set explicitly.
# CORS_ORIGINS=https://app.fireai.org,https://admin.fireai.org
CORS_ORIGINS=

# ── Content Security Policy ──────────────────────────────────────────────
# Set to "true" only if three.js/recharts require unsafe-eval in production.
CSP_UNSAFE_EVAL=false
# Additional connect-src origins (space-separated) for production.
CSP_CONNECT_SRC=

# ── File Uploads ──────────────────────────────────────────────────────────
FIREAI_DATA_DIRS=/tmp/fireai_uploads:/data:/uploads
FIREAI_ALLOWED_UPLOAD_DIRS=/tmp:/var/tmp:/var/fireai/uploads
FIREAI_DWG_MAX_FILE_SIZE_BYTES=104857600

# ── Logging ───────────────────────────────────────────────────────────────
LOG_LEVEL=INFO

# ── Sentry (optional) ────────────────────────────────────────────────────
SENTRY_DSN=

{
	"$schema": "https://openapi.vercel.sh/vercel.json",
	"framework": "vite",
	"buildCommand": "cd frontend && npm run build",
	"outputDirectory": "frontend/dist",
	"installCommand": "cd frontend && npm ci --no-audit --no-fund",
	"speedInsights": false,
	"webAnalytics": false,
	"rewrites": [
		{ "source": "/((?!api/).*)", "destination": "/" }
	]
}
